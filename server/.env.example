# MongoDB Connection String
# Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.mongodb.net/kisankanoon?retryWrites=true&w=majority

# JWT Secret — change this to any random string
JWT_SECRET=kisankanoon_super_secret_key_2025

# Cloudinary (free image storage) — sign up at cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Port (Render.com sets this automatically)
PORT=3000
